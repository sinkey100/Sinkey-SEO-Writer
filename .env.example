# sinkey-seo-writer — 环境变量模板
# 复制为 .env 并按需填写（也可用 `python3 setup.py KEY=...` 自动写入）。
# .env 已被 .gitignore 忽略，绝不要提交真实密钥。
#
# 重要：这些全部「按需」。不指定模型时由宿主 Agent 模型写作，下面任何 KEY 都不需要。
# 只有当你让某一步用某个具体第三方模型、或启用 Tavily 搜索时，才需要对应的 KEY。
# 所有第三方模型统一经 OpenRouter 调用，只需这一个 Key；模型清单见 scripts/models.yaml。

# --- LLM（按需）---
# 一个 Key 覆盖所有第三方模型（deepseek / qwen / kimi / gemini / claude … 全走 OpenRouter）。
OPENROUTER_API_KEY=

# --- 联网搜索（可选）---
# 设置后 scripts/search.py 才用 Tavily；不设则改用宿主 Agent 的 web 搜索或降级。
TAVILY_API_KEY=

# --- 网络代理（可选）---
# OpenRouter 的 proxy: true 仅当设了 HTTP_PROXY 才生效；为空则直连。
HTTP_PROXY=
